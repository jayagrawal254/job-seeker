# Server
PORT=4000
DATABASE_URL=file://${PWD}/data/company_profile.sql

# MySQL (local analysis DB — do NOT point at the real hirist/iimjobs DB;
# the import script drops/recreates company_profile and recruiter_profile)
DB_HOST=127.0.0.1
DB_USER=recly
DB_PASSWORD=recly_password
DB_NAME=recly_v2
DB_CONNECTION_LIMIT=5

# Gmail SMTP — requires a Google App Password (NOT your normal password):
#   Google Account -> Security -> 2-Step Verification (enable) -> App passwords
#   -> create one for "Mail", paste the 16 chars below (spaces don't matter)
# Leave SMTP_HOST empty for DRY-RUN (send script logs instead of sending).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=Your Name <your.email@gmail.com>

# Sender profile id stamped on queued mails (profile table comes later)
MAIL_USER_ID=1

# Pacing for the send script: random 30-60s gap between mails, max 100 per run.
# Gmail free tier allows ~500 mails/day — stay well below for cold outreach.
MAIL_MIN_GAP_MS=30000
MAIL_MAX_GAP_MS=60000
MAIL_MAX_PER_RUN=100

# Public base URL for the open-tracking pixel. On localhost, opens are only
# tracked from your own browser — use a tunnel (ngrok etc.) or hosted URL
# for real recipients' opens to register.
TRACKING_BASE_URL=http://localhost:4000
