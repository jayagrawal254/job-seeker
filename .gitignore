# ---- dependencies ----
node_modules/
**/node_modules/

# ---- secrets / config (NEVER commit — contains Gmail App Password / DB creds) ----
.env
.env.*
!.env.example

# ---- SQL dumps (regenerated by the pipeline; large) ----
*.sql

# ---- pipeline data artifacts (raw exports + intermediates, up to ~150 MB each) ----
pipeline/*.json
pipeline/**/*.json

# ---- backend data: imported dumps + uploaded resumes ----
backend/data/*.sql
!backend/data/company_profile.sql
!backend/data/recruiter_profile.sql
backend/data/*.db
!backend/data/dummy.db
backend/data/resumes/*
!backend/data/resumes/.gitkeep

# ---- frontend build output ----
frontend/dist/
frontend/.vite/

# ---- logs / OS / editor ----
*.log
npm-debug.log*
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
